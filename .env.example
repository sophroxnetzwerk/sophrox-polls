# Sophrox Polls - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# NODE ENVIRONMENT
# ============================================================================
NODE_ENV=production
PORT=3000

# ============================================================================
# DATABASE
# ============================================================================
# For SQLite (default):
DATABASE_URL=file:./dev.db
# For PostgreSQL (alternative):
# DATABASE_URL=postgresql://user:password@postgres:5432/sophrox_polls

# ============================================================================
# JWT SECRETS - GENERATE SECURE RANDOM VALUES IN PRODUCTION
# ============================================================================
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production

# ============================================================================
# DISCORD OAUTH CONFIGURATION
# ============================================================================
# Get these from Discord Developer Portal: https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# Redirect URI - MUST match Discord Developer Portal callback URL
# Format: https://your-domain.com/auth/discord (or http://localhost:5173/auth/discord for local dev)
DISCORD_REDIRECT_URI=http://localhost:5173/auth/discord

# ============================================================================
# DISCORD BOT CONFIGURATION
# ============================================================================
# Discord Bot Token for syncing role colors
DISCORD_BOT_TOKEN=your_discord_bot_token

# Discord Admin User ID (your Discord ID)
DISCORD_ADMIN_ID=your_discord_user_id

# Discord Guild/Server ID where the polls are used
DISCORD_GUILD_ID=your_discord_guild_id

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Frontend URL - this is the ONLY origin that can make requests
# Local: http://localhost:5173
# Production: https://your-domain.com
CORS_ORIGIN=http://localhost:5173

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
# API Base URL (how frontend contacts backend)
# Local: http://localhost:3000/api/v1
# Production: https://api.your-domain.com/api/v1 (or same as frontend domain)
VITE_API_BASE=http://localhost:3000/api/v1

# Discord Client ID (same as above, needed in frontend)
VITE_DISCORD_CLIENT_ID=your_discord_client_id

# Frontend URL (for redirects after OAuth)
VITE_FRONTEND_URL=http://localhost:5173

# ============================================================================
# OPTIONAL: API BASE URL (internal)
# ============================================================================
API_BASE_URL=http://localhost:3000

# ============================================================================
# DOCKER / PRODUCTION DEPLOYMENT NOTES
# ============================================================================
# 1. Generate strong random secrets:
#    JWT_SECRET=$(openssl rand -base64 32)
#    JWT_REFRESH_SECRET=$(openssl rand -base64 32)
#
# 2. For HTTPS deployment, update:
#    - DISCORD_REDIRECT_URI to https://your-domain.com/auth/discord
#    - CORS_ORIGIN to https://your-domain.com
#    - VITE_API_BASE accordingly
#
# 3. Backend only accepts requests from CORS_ORIGIN
#    No external API calls except Discord OAuth flow
#
# 4. Discord OAuth flow:
#    - Frontend redirects to Discord login → Discord → Backend callback → Frontend
#    - This is the only external communication needed
#
# 5. For docker-compose deployment:
#    - Copy this to .env.production
#    - Run: docker-compose --env-file .env.production up -d
